{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@precog/autocomplete-specs#build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"]
    },
    "amazon-q-for-cli-legacy-gnome-integration#build": {
      "dependsOn": ["^build"],
      "outputs": ["*.zip"]
    },
    "codewhisperer-for-command-line-companion#build": {
      "dependsOn": ["^build"],
      "outputs": ["*.vsix"]
    },
    "lint": {
      "dependsOn": ["@amzn/eslint-config#build"],
      "cache": false
    },
    "lint:fix": {
      "dependsOn": ["@amzn/eslint-config#build"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
