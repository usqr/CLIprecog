{
  "name": "@precog/autocomplete-specs",
  "version": "0.1.0",
  "private": true,
  "description": "Vendored Fig autocomplete specs (subcommand/flag/argument descriptors). Compiled to ./build/ and served by the Precog desktop overlay over the spec://localhost protocol.",
  "license": "MIT",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "autocomplete-tools compile",
    "build:index": "node ./scripts/generate-index.mjs",
    "clean": "rm -rf build .turbo"
  },
  "files": ["src", "build", "LICENSE", "UPSTREAM-README.md"],
  "dependencies": {
    "@fig/autocomplete-generators": "^2.4.0",
    "@fig/autocomplete-helpers": "^2.0.0",
    "semver": "^7.7.2",
    "strip-json-comments": "^3.1.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@withfig/autocomplete-tools": "^2.11.0",
    "@withfig/autocomplete-types": "^1.31.0",
    "typescript": "^5.8.3"
  }
}
